# ============================================================
# terraform.tfvars.example
# F5 BIG-IP Next for Kubernetes — Sprint 0 (AWS retarget in progress)
#
# Sprint 0 ships the AWS-shaped inputs for the eks_cluster module
# (Sprint 1). Module-specific inputs (cert_manager, flo, cne_instance,
# license, testing, s3 supply chain) land in Sprints 2 + 3; see
# docs/PLAN.md for the schedule.
#
# Usage:
#   cp terraform.tfvars.example terraform.tfvars
#   # edit terraform.tfvars
#   terraform init
#   terraform plan          # Sprint 0 expects this to validate
#   terraform apply         # Sprint 0 deliberately FAILS at this step
#                           # (eks_cluster stub fail-stops; see
#                           #  docs/prd/07-EKS-CLUSTER-SRIOV.md)
# ============================================================


# ============================================================
# eks_cluster (Sprint 1 — PRD 07)
# ============================================================

# AWS region for the EKS cluster (e.g. us-east-1, us-west-2, eu-west-1).
region = "us-east-1"

# EKS cluster name.
cluster_name = "awsbnk-demo"

# Kubernetes version. Default per PRD 07.
cluster_version = "1.30"

# Existing VPC to host the cluster.
# Sprint 1 will add `create_vpc = true` to provision a fresh VPC.
vpc_id = "vpc-REPLACE_ME"

# Private subnet IDs (>=3 AZs per PRD 07's HA target).
subnet_ids = [
  "subnet-REPLACE_ME_AZ_A",
  "subnet-REPLACE_ME_AZ_B",
  "subnet-REPLACE_ME_AZ_C",
]

# Self-managed node group instance types.
# c5n.4xlarge is the PRD 07 default for SR-IOV via ENA;
# c5n.9xlarge / m5n.4xlarge are valid alternatives.
node_instance_types = ["c5n.4xlarge"]

node_min_size     = 2
node_desired_size = 3
node_max_size     = 10
