/bin/
/awsbnkctl
/roksbnkctl
*.test
*.out
*.exe
*.exe~
.DS_Store

# awsbnkctl-managed state, never commit
.awsbnkctl/
# legacy fork-point name; harmless to keep until Sprint 5 polish removes it
.roksbnkctl/

# IDE
.vscode/
.idea/

# goreleaser
dist/

# terraform provider + module download cache (~hundreds of MB per module);
# .terraform.lock.hcl is the pin file and IS committed
.terraform/
*.tfstate
*.tfstate.backup
.terraform.tfstate.lock.info

# mdBook build output — generated by `make book` / `mdbook build book/`
# and deployed by .github/workflows/book.yml; never commit
book/book/

# Claude Code local state (worktrees, scheduled tasks, per-user settings)
.claude/

# Local secrets / per-run overrides for scripts/e2e-test-full.sh.
# Source with `set -a; . .env; set +a` before invoking the script.
# NEVER commit — will carry AWS_* credentials + workspace overrides
# once Sprint 4 rehydrates the e2e drivers. Copy .env.example as a
# starting point if one ever lands.
.env
.env.local
.env.*.local

# --- Added by multi-agent-framework installer ---
# OS
Thumbs.db
# Editor
*.swp
*.swo
# Node
node_modules/
package-lock.json
# Python
__pycache__/
*.pyc
.venv/
venv/
# Environment
# --- MAF downstream runtime artifacts (installer-managed) ---
# Keep framework-managed tooling/scaffolding versioned (for example `bin/maf-*`,
# `.agent/rules/*`, `.agent/templates/*`). Ignore only operational/runtime artifacts.
# OpenCode runtime state
.opencode/state/
# Local provider override notes (per-machine, never committed)
.opencode/PROVIDER-LOCAL.md
.opencode/*.local.*
# Framework operational artifacts
.agent/tmp/
.agent/cache/
.agent/**/*.maf.new
.agent/install-state.yaml
# Multi-agent runtime/session artifacts (keep scaffold dirs only)
.agent/tasks/active/**
!.agent/tasks/active/.gitkeep
.agent/tasks/done/**
!.agent/tasks/done/.gitkeep
.agent/memory/archive/**
!.agent/memory/archive/.gitkeep
.agent/memory/sessions/**
!.agent/memory/sessions/.gitkeep
.agent/work/**
!.agent/work/.gitkeep
# --- End MAF downstream runtime artifacts ---
