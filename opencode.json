{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 25000
  },
  "agent": {
    "compaction": {
      "model": "anthropic/claude-haiku-4-5"
    }
  },
  "instructions": [
    ".agent/AGENTS.md",
    ".agent/ACTIVE_CONTEXT.md"
  ],
  "default_agent": "lead",
  "provider": {
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "{env:LLM_API_KEY}"
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude 4.7 Opus",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-opus-4-6": {
          "name": "Claude 4.6 Opus",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude 4.6 Sonnet",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-sonnet-4-5": {
          "name": "Claude 4.5 Sonnet",
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "claude-haiku-4-5": {
          "name": "Claude 4.5 Haiku",
          "limit": {
            "context": 200000,
            "output": 64000
          }
        }
      }
    }
  },
  "enabled_providers": [
    "anthropic"
  ],
  "share": "disabled",
  "model": "anthropic/claude-opus-4-7",
  "small_model": "anthropic/claude-haiku-4-5",
  "permission": {
    "bash": {
      "*": "allow",
      "git push *": "deny",
      "rm -rf *": "deny"
    },
    "edit": "allow",
    "webfetch": "ask",
    "websearch": "ask"
  }
}
