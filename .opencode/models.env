# OpenCode Model Assignments
#
# Maps framework tiers to actual model IDs via the configured LLM provider.
# This is the ONE FILE you edit to change models.
#
# After editing, run:  bin/maf-models.sh apply
#
# Format: TIER_MODEL=provider/model-id
# The provider prefix (e.g., "anthropic/") must match a provider in opencode.json

# --- Tier Assignments (Anthropic public-release defaults, per ADR-026) ---
FRONTIER_MODEL=anthropic/claude-opus-4-7
WORKHORSE_MODEL=anthropic/claude-sonnet-4-6
FAST_MODEL=anthropic/claude-haiku-4-5

# --- Utility Models ---
# Compaction summarizer (runs during context compaction)
COMPACTION_MODEL=anthropic/claude-haiku-4-5

# --- Per-Role Overrides (optional) ---
# Uncomment to assign a specific model to a role, overriding its tier.
# Example: use a different Anthropic model for one role.
#LEAD_MODEL=anthropic/claude-opus-4-7
#ARCHITECT_MODEL=anthropic/claude-sonnet-4-6
#BUILDER_MODEL=anthropic/claude-haiku-4-5
#REVIEWER_MODEL=anthropic/claude-sonnet-4-6
